pipeline {
    agent any

    stages {
        stage('Clone Code') {
            steps {
                git  https://github.com/surajgharde/event_registration.git
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t flask-app .'
            }
        }


        stage('Run Container') {
            steps {
                sh 'docker run -d -p 5000:5000 flask-app'
            }
        }
    }
}